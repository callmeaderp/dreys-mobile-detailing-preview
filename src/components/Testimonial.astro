---
export interface Props {
  quote: string;
  author: string;
  location?: string;
  stars?: number;
}

const { quote, author, location, stars = 5 } = Astro.props;
const filled = "★".repeat(stars);
const empty = "☆".repeat(5 - stars);
---

<figure class="card flex flex-col h-full">
  <div class="text-accent-500 text-lg mb-3" aria-label={`${stars} out of 5 stars`}>
    <span aria-hidden="true">{filled}<span class="text-ink-300">{empty}</span></span>
  </div>
  <blockquote class="text-ink-700 leading-relaxed flex-1">
    <p>"{quote}"</p>
  </blockquote>
  <figcaption class="mt-4 pt-4 border-t border-ink-200">
    <div class="font-semibold text-brand-900">{author}</div>
    {location && <div class="text-sm text-ink-500">{location}</div>}
  </figcaption>
</figure>
