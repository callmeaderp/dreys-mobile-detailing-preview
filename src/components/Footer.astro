---
import { site, telHref, smsHref, mailHref } from "../data/site";
import { services } from "../data/services";
import { u } from "../data/url";

const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-950 text-white">
  <div class="container-page py-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
    <!-- Brand column -->
    <div>
      <div class="flex items-center gap-3 mb-4">
        <div class="flex items-center justify-center w-12 h-12 rounded-md bg-accent-500 text-brand-950 font-bold text-xl">
          {site.logoInitials}
        </div>
        <div>
          <div class="font-bold text-lg">{site.name}</div>
          <div class="text-accent-300 italic text-sm">{site.tagline}</div>
        </div>
      </div>
      <p class="text-ink-300 text-sm leading-relaxed mb-4">
        Mobile auto, marine, RV, and power sports detailing in Victor, NY and the Finger Lakes. Family-owned since {site.established}.
      </p>
      <div class="flex gap-3">
        <a href={site.social.facebook} aria-label="Facebook" class="w-9 h-9 rounded-md bg-brand-800 hover:bg-accent-500 hover:text-brand-950 flex items-center justify-center transition-colors" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>
        </a>
        <a href={site.social.instagram} aria-label="Instagram" class="w-9 h-9 rounded-md bg-brand-800 hover:bg-accent-500 hover:text-brand-950 flex items-center justify-center transition-colors" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9a5.5 5.5 0 0 1-5.5 5.5h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2zm0 2A3.5 3.5 0 0 0 4 7.5v9A3.5 3.5 0 0 0 7.5 20h9a3.5 3.5 0 0 0 3.5-3.5v-9A3.5 3.5 0 0 0 16.5 4h-9zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6zm5.5-3.25a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5z"/></svg>
        </a>
      </div>
    </div>

    <!-- Services column -->
    <div>
      <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Services</h3>
      <ul class="space-y-2 text-sm">
        {services.map((svc) => (
          <li>
            <a href={u(`/services/${svc.slug}/`)} class="text-ink-300 hover:text-accent-300 transition-colors">
              {svc.shortTitle}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Navigate column -->
    <div>
      <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Explore</h3>
      <ul class="space-y-2 text-sm">
        <li><a href={u("/")} class="text-ink-300 hover:text-accent-300 transition-colors">Home</a></li>
        <li><a href={u("/about/")} class="text-ink-300 hover:text-accent-300 transition-colors">About Andrew</a></li>
        <li><a href={u("/gallery/")} class="text-ink-300 hover:text-accent-300 transition-colors">Gallery</a></li>
        <li><a href={u("/service-area/")} class="text-ink-300 hover:text-accent-300 transition-colors">Service Area</a></li>
        <li><a href={u("/faq/")} class="text-ink-300 hover:text-accent-300 transition-colors">FAQ</a></li>
        <li><a href={u("/contact/")} class="text-ink-300 hover:text-accent-300 transition-colors">Contact / Book</a></li>
      </ul>
    </div>

    <!-- Contact column -->
    <div>
      <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Get In Touch</h3>
      <ul class="space-y-3 text-sm">
        <li class="flex gap-3">
          <span class="text-accent-400 mt-0.5" aria-hidden="true">📞</span>
          <div>
            <a href={telHref} class="text-white hover:text-accent-300 transition-colors font-medium">{site.phone.display}</a>
            <div class="text-ink-400 text-xs">
              <a href={smsHref} class="hover:text-accent-300">or text us</a>
            </div>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="text-accent-400 mt-0.5" aria-hidden="true">✉️</span>
          <a href={mailHref} class="text-ink-300 hover:text-accent-300 transition-colors break-all">{site.email}</a>
        </li>
        <li class="flex gap-3">
          <span class="text-accent-400 mt-0.5" aria-hidden="true">📍</span>
          <div class="text-ink-300">
            {site.address.street}<br />
            {site.address.locality}, {site.address.region} {site.address.postal}
          </div>
        </li>
        <li class="flex gap-3">
          <span class="text-accent-400 mt-0.5" aria-hidden="true">🕒</span>
          <div class="text-ink-300 text-sm">
            <div>Mon–Fri: 9am – 5pm</div>
            <div>Sat: By appointment</div>
            <div>Sun: Closed</div>
          </div>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-brand-800">
    <div class="container-page py-5 flex flex-col md:flex-row items-center justify-between gap-2 text-xs text-ink-400">
      <div>
        © {currentYear} {site.legalName}. All rights reserved. · Est. {site.established}
      </div>
      <div>
        Proudly serving Victor, Rochester &amp; the Finger Lakes
      </div>
    </div>
  </div>
</footer>
