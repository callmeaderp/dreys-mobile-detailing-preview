---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBar from "../components/CtaBar.astro";
import { site } from "../data/site";

import civicTypeR from "../assets/gallery/civic-type-r.jpg";
import bmw3Series from "../assets/gallery/bmw-3-series.jpg";
import audiQ5 from "../assets/gallery/audi-q5.jpg";
import ram1500 from "../assets/gallery/ram-1500.jpg";
import dodgeViper from "../assets/gallery/dodge-viper.jpg";
import miniInterior from "../assets/gallery/mini-cooper-interior.jpg";
import datsunRoadster from "../assets/gallery/datsun-roadster.jpg";

const title = "Gallery | Drey's Mobile Detailing — Recent Work";
const description =
  "Real photos from recent details — daily drivers, trucks, classics, and exotics detailed in Victor, NY and the Finger Lakes. See the finish we deliver.";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Gallery", url: "/gallery/" },
];

// Real photos from completed jobs (owner's camera roll + social pages)
const galleryItems = [
  {
    image: civicTypeR,
    alt: "Bright blue Honda Civic Type R freshly detailed in a driveway",
    label: "Honda Civic Type R",
    category: "Full Detail",
  },
  {
    image: dodgeViper,
    alt: "Black Dodge Viper with a mirror-gloss finish in a garage",
    label: "Dodge Viper",
    category: "Show-Car Prep",
  },
  {
    image: audiQ5,
    alt: "Black Audi Q5 with clouds reflecting in the polished hood",
    label: "Audi Q5",
    category: "Paint Enhancement",
  },
  {
    image: ram1500,
    alt: "Black RAM 1500 pickup mid-detail with doors open",
    label: "RAM 1500",
    category: "Full Detail",
  },
  {
    image: bmw3Series,
    alt: "Glossy black BMW 3 Series after a full detail",
    label: "BMW 3 Series",
    category: "Full Detail",
  },
  {
    image: miniInterior,
    alt: "Spotless MINI Cooper interior after deep cleaning",
    label: "MINI Cooper",
    category: "Interior Detail",
  },
  {
    image: datsunRoadster,
    alt: "Restored classic Datsun roadster with deep red paint",
    label: "Classic Datsun Roadster",
    category: "Classic Care",
  },
];
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs}>
  <section class="bg-brand-950 text-white py-20 md:py-28">
    <div class="container-page max-w-4xl">
      <span class="eyebrow text-accent-400">Our Work</span>
      <h1 class="text-4xl md:text-5xl font-semibold mt-3 mb-5 text-white">
        Recent work from the driveway
      </h1>
      <p class="text-ink-200 text-lg leading-relaxed mb-6">
        Detailing is a visual craft. These are real vehicles from real jobs — daily drivers, trucks, classics, and exotics that left looking the way their owners remember them.
      </p>
      <p class="text-accent-300 text-sm">
        More photos continuously posted on our <a href={site.social.instagram} class="underline hover:text-accent-200" target="_blank" rel="noopener">Instagram</a> and <a href={site.social.facebook} class="underline hover:text-accent-200" target="_blank" rel="noopener">Facebook</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-page">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {galleryItems.map((item) => (
          <figure class="group relative aspect-[4/3] rounded-2xl overflow-hidden border border-ink-200 hover:border-accent-400 transition-colors">
            <Image
              src={item.image}
              alt={item.alt}
              widths={[480, 800, 1200]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <figcaption class="absolute inset-0 flex items-end p-5 bg-gradient-to-t from-black/70 via-black/10 to-transparent">
              <div>
                <div class="text-accent-300 text-xs uppercase tracking-widest font-bold mb-1">
                  {item.category}
                </div>
                <div class="text-white text-xl font-semibold leading-tight">
                  {item.label}
                </div>
              </div>
            </figcaption>
          </figure>
        ))}
      </div>

      <div class="mt-12 text-center max-w-2xl mx-auto">
        <p class="text-ink-600 italic">
          For the latest work, follow us on Instagram and Facebook — new details posted regularly.
        </p>
      </div>
    </div>
  </section>

  <CtaBar
    heading="Want your ride to look like this?"
    subheading="Book a detail and we'll get started on your transformation."
  />
</BaseLayout>
