---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBar from "../components/CtaBar.astro";
import Placeholder from "../components/Placeholder.astro";
import { site } from "../data/site";

const title = "Gallery | Drey's Mobile Detailing — Before & After";
const description =
  "Before and after photos from recent details — auto, marine, RV, and power sports. See the transformation we bring to vehicles in Victor, NY and the Finger Lakes.";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Gallery", url: "/gallery/" },
];

// Gallery entries — these would eventually link to real images.
// For now, use styled placeholders that show what each category covers.
const galleryItems = [
  { label: "Full Paint Correction", category: "Auto", color: "from-brand-800 to-brand-950" },
  { label: "Ceramic Coating Install", category: "Auto", color: "from-accent-600 to-accent-800" },
  { label: "Classic Restoration", category: "Auto", color: "from-ink-700 to-ink-900" },
  { label: "Gelcoat Oxidation Removal", category: "Marine", color: "from-blue-700 to-blue-950" },
  { label: "Pontoon Deep Clean", category: "Marine", color: "from-cyan-700 to-cyan-950" },
  { label: "Class A Motorhome", category: "RV", color: "from-green-700 to-green-950" },
  { label: "Travel Trailer Detail", category: "RV", color: "from-emerald-700 to-emerald-950" },
  { label: "Harley-Davidson Detail", category: "Power Sports", color: "from-red-800 to-red-950" },
  { label: "Side-by-Side Mud Recovery", category: "Power Sports", color: "from-amber-700 to-amber-950" },
];
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs}>
  <section class="bg-brand-950 text-white py-20 md:py-28">
    <div class="container-page max-w-4xl">
      <span class="eyebrow text-accent-400">Our Work</span>
      <h1 class="text-4xl md:text-5xl font-semibold mt-3 mb-5 text-white">
        Recent work from the driveway
      </h1>
      <p class="text-ink-200 text-lg leading-relaxed mb-6">
        Detailing is a visual craft. The best way to show the difference is to show before and after — cars, boats, RVs, and bikes that came in dull, dirty, or oxidized and left looking the way their owners remember them.
      </p>
      <p class="text-accent-300 text-sm">
        More photos continuously posted on our <a href={site.social.instagram} class="underline hover:text-accent-200" target="_blank" rel="noopener">Instagram</a> and <a href={site.social.facebook} class="underline hover:text-accent-200" target="_blank" rel="noopener">Facebook</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-page">
      <Placeholder
        note="All tiles are color-gradient stand-ins, not real photos. Source images exist on the Facebook and Instagram pages and in the original camera roll (IMG_3919, IMG_3313, IMG_1052, etc.). Target: 6–12 of the strongest before/after transformations across auto, marine, RV, and power sports."
      >
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {galleryItems.map((item) => (
            <figure class="group relative aspect-[4/3] rounded-2xl overflow-hidden border border-ink-200 hover:border-accent-400 transition-colors">
              <div class={`absolute inset-0 bg-gradient-to-br ${item.color}`} aria-hidden="true"></div>
              <div class="absolute inset-0 flex items-end p-5 bg-gradient-to-t from-black/70 via-black/20 to-transparent">
                <div>
                  <div class="text-accent-300 text-xs uppercase tracking-widest font-bold mb-1">
                    {item.category}
                  </div>
                  <div class="text-white text-xl font-semibold leading-tight">
                    {item.label}
                  </div>
                </div>
              </div>
              <div class="absolute top-3 right-3 bg-white/90 text-brand-900 text-xs font-semibold px-2 py-1 rounded">
                Before &amp; After
              </div>
            </figure>
          ))}
        </div>
      </Placeholder>

      <div class="mt-12 text-center max-w-2xl mx-auto">
        <p class="text-ink-600 italic">
          Photo library currently being migrated from social platforms to the new gallery. For the latest work, follow us on Instagram and Facebook.
        </p>
      </div>
    </div>
  </section>

  <CtaBar
    heading="Want your ride to look like this?"
    subheading="Book a detail and we'll get started on your transformation."
  />
</BaseLayout>
