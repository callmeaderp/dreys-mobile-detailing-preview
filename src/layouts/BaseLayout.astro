---
import { site } from "../data/site";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { u } from "../data/url";
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  // Optional extra structured data for this page (e.g. Service, FAQPage)
  schema?: object | object[];
  // Breadcrumb trail (optional) — array of {name, url}
  breadcrumbs?: Array<{ name: string; url: string }>;
  noindex?: boolean;
}

const {
  title,
  description,
  image = u("/og-image.svg"),
  canonical,
  schema,
  breadcrumbs,
  // Preview build: noindex everything by default so the preview doesn't
  // compete with / pre-empt the live domain once it's configured.
  noindex = true,
} = Astro.props;

const canonicalURL = new URL(canonical ?? Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site).toString();

// LocalBusiness schema — on every page so Google sees it everywhere.
// Fixes the issues found in the audit: proper @id, real image, protocol,
// country, real hours (uses specialClosing/opening notation instead of 00:00-00:00).
const businessSchema = {
  "@context": "https://schema.org",
  "@type": "AutoDetailing",
  "@id": `${site.url}/#business`,
  name: site.name,
  legalName: site.legalName,
  alternateName: site.shortName,
  slogan: site.tagline,
  description:
    "Mobile auto, marine, RV, and power sports detailing in Victor, NY and the Finger Lakes. Ceramic coating, paint correction, and full detailing — we come to you.",
  url: site.url,
  image: `${site.url}/og-image.svg`,
  logo: `${site.url}/logo.svg`,
  telephone: site.phone.tel,
  email: site.email,
  priceRange: site.priceRange,
  foundingDate: site.established,
  founder: { "@type": "Person", name: site.owner },
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address.street,
    addressLocality: site.address.locality,
    addressRegion: site.address.region,
    postalCode: site.address.postal,
    addressCountry: site.address.country,
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: site.geo.latitude,
    longitude: site.geo.longitude,
  },
  areaServed: site.serviceArea.map((a) => ({ "@type": "City", name: a })),
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "09:00",
      closes: "17:00",
    },
    // Saturday by appointment — modeled as hoursAvailable note in description
  ],
  sameAs: [site.social.facebook, site.social.instagram],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Detailing Services",
    itemListElement: [
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Auto Detailing" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Ceramic Coating" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Paint Correction" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Boat & Marine Detailing" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "RV Detailing" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Power Sports Detailing" } },
    ],
  },
};

// Breadcrumb schema
const breadcrumbSchema = breadcrumbs
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: breadcrumbs.map((b, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: b.name,
        item: new URL(b.url, site.url).toString(),
      })),
    }
  : null;

// Combine all schemas
const allSchemas: object[] = [businessSchema];
if (breadcrumbSchema) allSchemas.push(breadcrumbSchema);
if (schema) {
  if (Array.isArray(schema)) allSchemas.push(...schema);
  else allSchemas.push(schema);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href={u("/favicon.svg")} />
    <link rel="alternate icon" href={u("/favicon.ico")} />
    <link rel="apple-touch-icon" href={u("/apple-touch-icon.png")} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Geo meta -->
    <meta name="geo.region" content="US-NY" />
    <meta name="geo.placename" content="Victor, NY" />
    <meta name="geo.position" content={`${site.geo.latitude};${site.geo.longitude}`} />
    <meta name="ICBM" content={`${site.geo.latitude}, ${site.geo.longitude}`} />

    <!-- Theme color -->
    <meta name="theme-color" content="#141f39" />

    <!-- Fonts: Inter + Playfair Display, preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data -->
    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Google Analytics 4 (preserves existing tracking from old site) -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${site.analytics.ga4}`}></script>
    <script is:inline define:vars={{ id: site.analytics.ga4 }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', id);
    </script>
  </head>

  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-accent-500 focus:text-brand-950 focus:px-3 focus:py-2 focus:rounded-md">
      Skip to content
    </a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
